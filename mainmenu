# ═══════════════════════════════════════════════════════════════
#   MODULE 4 — MANAGER  (Wings service manager)
# ═══════════════════════════════════════════════════════════════
module_manager() {
    while true; do
        clear; echo ""
        local svc_status svc_color
        if systemctl is-active --quiet wings 2>/dev/null; then
            svc_status="${CHECKMARK} RUNNING"; svc_color="${BRIGHT_GREEN}${BD}"
        else
            svc_status="${CROSSMARK} STOPPED"; svc_color="${BRIGHT_RED}${BD}"
        fi

        echo -e "   ${BRIGHT_CYAN}┌──────────────────────────────────────────────────────┐${NC}"
        echo -e "   ${BRIGHT_CYAN}│${NC}  ${BRIGHT_YELLOW}${BD}⚙  WINGS MANAGER${NC}  ${DARK_GRAY}::${NC}  ${svc_color}Wings: ${svc_status}${NC}"
        echo -e "   ${BRIGHT_CYAN}└──────────────────────────────────────────────────────┘${NC}"
        echo ""
        echo -e "   ${BRIGHT_GREEN}  [1]${NC}  ${WHITE}Start Wings${NC}"
        echo -e "   ${BRIGHT_RED}  [2]${NC}  ${WHITE}Stop Wings${NC}"
        echo -e "   ${BRIGHT_YELLOW}  [3]${NC}  ${WHITE}Restart Wings${NC}"
        echo -e "   ${BRIGHT_CYAN}  [4]${NC}  ${WHITE}Status / Info${NC}"
        echo -e "   ${BRIGHT_MAGENTA}  [5]${NC}  ${WHITE}Live Logs${NC}"
        echo -e "   ${DARK_GRAY}  [0]${NC}  ${WHITE}Back${NC}"
        echo ""
        echo -e "   ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
        echo ""
        printf "   ${BRIGHT_GREEN}root@wings-manager:~# ${NC}"; read -r mc

        case "$mc" in
            1) systemctl start   wings 2>/dev/null && print_success "Wings started"   || print_error "Failed"; sleep 1 ;;
            2) systemctl stop    wings 2>/dev/null && print_success "Wings stopped"   || print_error "Failed"; sleep 1 ;;
            3) systemctl restart wings 2>/dev/null && print_success "Wings restarted" || print_error "Failed"; sleep 1 ;;
            4) clear; systemctl status wings; pause ;;
            5) clear; echo -e "   ${DIM}Press Ctrl+C to exit logs${NC}"; echo ""; journalctl -u wings -f ;;
