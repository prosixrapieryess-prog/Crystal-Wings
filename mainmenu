# ═══════════════════════════════════════════════════════════════
#   MODULE 1 — SSL CONFIGURATION  (Certbot + Nginx)
# ═══════════════════════════════════════════════════════════════
module_ssl() {
    clear; show_banner
    print_header "SSL CONFIGURATION — Certbot / Nginx"
    require_root || return

    # Get domain
    echo -ne "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}Enter your domain (e.g. panel.example.com): ${NC}"
    read -r domain
    [[ -z "$domain" ]] && { print_error "Domain cannot be empty."; pause; return; }

    # Get email
    echo -ne "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}Enter your email for Let's Encrypt: ${NC}"
    read -r email
    [[ -z "$email" ]] && { print_error "Email cannot be empty."; pause; return; }

    print_divider

    print_status "Installing Nginx"
    (apt-get update -qq >/dev/null 2>&1 && apt-get install -y -qq nginx >/dev/null 2>&1) &
    spinner "Installing Nginx"

    print_status "Installing Certbot"
    (apt-get install -y -qq certbot python3-certbot-nginx >/dev/null 2>&1) &
    spinner "Installing Certbot"

    print_status "Stopping Nginx temporarily"
    systemctl stop nginx 2>/dev/null || true

    print_status "Obtaining SSL certificate for ${domain}"
    if certbot certonly --standalone \
        --non-interactive --agree-tos \
        --email "$email" \
        -d "$domain" 2>/dev/null; then
        print_success "Certificate obtained for ${domain}"
    else
        print_error "Certbot failed — check DNS points to this server"
        pause; return
    fi

    print_status "Writing Nginx config"
    cat > "/etc/nginx/sites-available/${domain}.conf" <<NGINXEOF
server {
    listen 80;
    server_name ${domain};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    server_name ${domain};

    ssl_certificate     /etc/letsencrypt/live/${domain}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${domain}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    location / {
        proxy_pass http://localhost:80;
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
    }
}
NGINXEOF

    ln -sf "/etc/nginx/sites-available/${domain}.conf" \
           "/etc/nginx/sites-enabled/${domain}.conf" 2>/dev/null || true

    print_status "Restarting Nginx"
    (nginx -t >/dev/null 2>&1 && systemctl restart nginx >/dev/null 2>&1) &
    spinner "Nginx restart"

    progress_bar "SSL Setup"
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  SSL Certificate Issued!              ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${WHITE}  Domain : ${BRIGHT_CYAN}${domain}${BRIGHT_GREEN}                    ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${WHITE}  Cert   : ${BRIGHT_CYAN}/etc/letsencrypt/live/${domain}/${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    pause
}

