# ═══════════════════════════════════════════════════════════════
#   OPTION 1 — AUTO-SETUP  (Install + Config Wizard)
# ═══════════════════════════════════════════════════════════════
run_autosetup() {

    # ── Root check ────────────────────────────────────────────
    _wings_configurator_header
    if [ "$EUID" -ne 0 ]; then
        echo -e "\n   ${BRIGHT_RED}╔══════════════════════════════════════╗${NC}"
        echo -e "   ${BRIGHT_RED}║  ${CROSSMARK}  ERROR: Must be run as root!       ║${NC}"
        echo -e "   ${BRIGHT_RED}╚══════════════════════════════════════╝${NC}\n"
        pause; return
    fi
    echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}Running as root — proceeding...${NC}"
    sleep 0.5

    # ── STEP 1 — Docker ──────────────────────────────────────
    print_header "STEP 1 — INSTALLING DOCKER"

    if command -v docker &>/dev/null; then
        print_info "Docker already installed — skipping"
    else
        print_status "Fetching Docker installation script"
        curl -sSL https://get.docker.com/ | CHANNEL=stable bash
        check_success "Docker installed successfully" "Docker installation failed"
    fi

    print_divider
    print_status "Enabling Docker service"
    systemctl enable --now docker > /dev/null 2>&1
    check_success "Docker service is active & enabled" "Failed to start Docker"
    progress_bar "Docker setup"

    # ── STEP 2 — GRUB ────────────────────────────────────────
    print_header "STEP 2 — CONFIGURING GRUB"

    GRUB_FILE="/etc/default/grub"
    if [ -f "$GRUB_FILE" ]; then
        print_status "Patching GRUB for swap accounting"
        sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="swapaccount=1"/' "$GRUB_FILE"
        update-grub > /dev/null 2>&1 || true
        check_success "GRUB updated successfully" "GRUB update failed"
        progress_bar "GRUB configuration"
    else
        print_info "GRUB file not found — skipping"
    fi

    # ── STEP 3 — Wings binary ────────────────────────────────
    print_header "STEP 3 — INSTALLING WINGS"

    print_status "Creating Pterodactyl directory"
    mkdir -p /etc/pterodactyl
    check_success "Directory /etc/pterodactyl created" "Failed to create directory"
    print_divider

    print_status "Detecting system architecture"
    ARCH=$(uname -m)
    if [ "$ARCH" == "x86_64" ]; then
        ARCH="amd64"
        print_info "Architecture detected: x86_64 → amd64"
    else
        ARCH="arm64"
        print_info "Architecture detected: ARM → arm64"
    fi
    print_divider

    print_status "Downloading Wings binary"
    curl -fsSL -o /usr/local/bin/wings \
        "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_${ARCH}" > /dev/null 2>&1
    check_success "Wings binary downloaded to /usr/local/bin/wings" "Failed to download Wings"
    print_divider

    print_status "Setting executable permissions"
    chmod u+x /usr/local/bin/wings
    check_success "Permissions set on Wings binary" "Failed to set permissions"
    progress_bar "Wings installation"

    # ── STEP 4 — Systemd service ─────────────────────────────
    print_header "STEP 4 — CONFIGURING SYSTEMD SERVICE"

    print_status "Writing Wings systemd service file"
    WINGS_SERVICE_FILE="/etc/systemd/system/wings.service"
    tee "$WINGS_SERVICE_FILE" > /dev/null <<'SVCEOF'
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service
PartOf=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=4096
PIDFile=/var/run/wings/daemon.pid
ExecStart=/usr/local/bin/wings
Restart=on-failure
StartLimitInterval=180
StartLimitBurst=30
RestartSec=5s

[Install]
WantedBy=multi-user.target
SVCEOF
    check_success "Service file created at $WINGS_SERVICE_FILE" "Failed to create service file"
    print_divider

    print_status "Reloading systemd daemon"
    systemctl daemon-reload > /dev/null 2>&1
    check_success "Systemd daemon reloaded" "Failed to reload systemd"
    print_divider

    print_status "Enabling Wings on boot"
    systemctl enable wings > /dev/null 2>&1
    check_success "Wings service enabled" "Failed to enable service"
    progress_bar "Service configuration"

    # ── STEP 5 — SSL certificate ─────────────────────────────
    print_header "STEP 5 — GENERATING SSL CERTIFICATE"

    print_status "Creating certificate directory"
    mkdir -p /etc/certs/wing
    check_success "Certificate directory ready" "Failed to create directory"
    print_divider

    print_status "Generating self-signed RSA 4096-bit certificate"
    openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
        -subj "/C=NA/ST=NA/L=NA/O=NA/CN=Generic SSL Certificate" \
        -keyout /etc/certs/wing/privkey.pem \
        -out    /etc/certs/wing/fullchain.pem > /dev/null 2>&1
    check_success "SSL certificate generated (valid 10 years)" "SSL generation failed"
    print_info "Private key : /etc/certs/wing/privkey.pem"
    print_info "Certificate : /etc/certs/wing/fullchain.pem"
    progress_bar "SSL generation"

    # ── STEP 6 — Helper command ──────────────────────────────
    print_header "STEP 6 — INSTALLING WING HELPER"

    print_status "Creating 'wing' helper command"
    tee /usr/local/bin/wing > /dev/null <<'WINGEOF'
#!/bin/bash
BCY='\033[1;36m'
YL='\033[1;33m'
GR='\033[0;32m'
MG='\033[0;35m'
NC='\033[0m'
BD='\033[1m'
echo ""
echo -e "  ${BCY}╔══════════════════════════════════════╗${NC}"
echo -e "  ${BCY}║${MG}${BD}   ⚙  WINGS HELPER — ProXLegendYT    ${BCY}║${NC}"
echo -e "  ${BCY}╠══════════════════════════════════════╣${NC}"
echo -e "  ${BCY}║  ${YL}start   ${NC}→ ${GR}sudo systemctl start wings  ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}stop    ${NC}→ ${GR}sudo systemctl stop wings   ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}restart ${NC}→ ${GR}sudo systemctl restart wings${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}status  ${NC}→ ${GR}sudo systemctl status wings ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}logs    ${NC}→ ${GR}sudo journalctl -u wings -f  ${BCY}║${NC}"
echo -e "  ${BCY}╚══════════════════════════════════════╝${NC}"
echo ""
WINGEOF
    chmod +x /usr/local/bin/wing
    check_success "Helper command 'wing' installed" "Failed to create helper"
    progress_bar "Helper setup"

    # ── Launch Configuration Wizard ──────────────────────────
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  Installation Complete!               ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${YELLOW}  Launching Configuration Wizard...       ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    sleep 1

    run_config_wizard
}

# ═══════════════════════════════════════════════════════════════
#   CONFIGURATION WIZARD  (Image 2 — step-by-step)
# ═══════════════════════════════════════════════════════════════
run_config_wizard() {
    local node_uuid="" token_id="" token_key="" api_port="" panel_url=""

    # helper: masked token display
    _mask() { printf '%*s' "${#1}" '' | tr ' ' '*'; }

    # helper: wizard sub-header (redrawn each step)
    _wiz_header() {
        _wings_configurator_header
        echo -e "   ${BRIGHT_MAGENTA}${BD}CONFIGURATION WIZARD${NC}"
        echo -e "   ${DIM}Enter credentials. Type ${WHITE}'back'${DIM} to go to previous step.${NC}"
        echo ""
    }

    # ── Step 1: Node UUID ─────────────────────────────────────
    step1() {
        while true; do
            _wiz_header
            printf "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Node UUID: ${NC}"
            read -r node_uuid
            [[ "$node_uuid" == "back" ]] && { node_uuid=""; return 1; }
            [[ -z "$node_uuid" ]] && { print_error "UUID cannot be empty."; sleep 1; continue; }
            return 0
        done
    }

    # ── Step 2: Token ID ──────────────────────────────────────
    step2() {
        while true; do
            _wiz_header
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"; echo ""
            printf "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token ID: ${NC}"
            read -r token_id
            [[ "$token_id" == "back" ]] && { token_id=""; return 1; }
            [[ -z "$token_id" ]] && { print_error "Token ID cannot be empty."; sleep 1; continue; }
            return 0
        done
    }

    # ── Step 3: Token Key ─────────────────────────────────────
    step3() {
        while true; do
            _wiz_header
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token ID : ${BRIGHT_CYAN}${token_id}${NC}"; echo ""
            printf "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token Key: ${NC}"
            read -r token_key
            [[ "$token_key" == "back" ]] && { token_key=""; return 1; }
            [[ -z "$token_key" ]] && { print_error "Token Key cannot be empty."; sleep 1; continue; }
            return 0
        done
    }

    # ── Step 4: API Port ──────────────────────────────────────
    step4() {
        while true; do
            _wiz_header
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token ID : ${BRIGHT_CYAN}${token_id}${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token Key: ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"; echo ""
            echo -e "   ${DIM}(Default: 8080) Press ENTER to use default${NC}"
            printf "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}API Port: ${NC}"
            read -r api_port
            [[ "$api_port" == "back" ]] && { api_port=""; return 1; }
            [[ -z "$api_port" ]] && api_port="8080"
            echo -e "   ${BRIGHT_YELLOW}  ⚠ Using Port: ${api_port}${NC}"; sleep 0.4
            return 0
        done
    }

    # ── Step 5: Panel URL ─────────────────────────────────────
    step5() {
        while true; do
            _wiz_header
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token ID : ${BRIGHT_CYAN}${token_id}${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Token Key: ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
            echo -e "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}API Port : ${BRIGHT_CYAN}${api_port}${NC}"; echo ""
            echo -e "   ${DIM}(Default: https://panel.example.com) Press ENTER to use default${NC}"
            printf "   ${BRIGHT_GREEN}${ARROW}${NC}${WHITE}Panel URL: ${NC}"
            read -r panel_url
            [[ "$panel_url" == "back" ]] && { panel_url=""; return 1; }
            [[ -z "$panel_url" ]] && panel_url="https://panel.example.com"
            echo -e "   ${BRIGHT_YELLOW}  ⚠ Using URL: ${panel_url}${NC}"; sleep 0.4
            return 0
        done
    }

    # ── Wizard navigation loop ────────────────────────────────
    local current_step=1
    while true; do
        case $current_step in
            1) step1 && current_step=2 || current_step=1 ;;
            2) step2 && current_step=3 || current_step=1 ;;
            3) step3 && current_step=4 || current_step=2 ;;
            4) step4 && current_step=5 || current_step=3 ;;
            5) step5 && break         || current_step=4  ;;
        esac
    done

    # ── Review screen ─────────────────────────────────────────
    _wiz_header
    echo -e "   ${BRIGHT_CYAN}${BD}REVIEW SETTINGS:${NC}"
    echo -e "   ${DARK_GRAY}  ──────────────────────────────────────────────────${NC}"
    echo -e "   ${WHITE}  ${DOT}  UUID      : ${BRIGHT_CYAN}${node_uuid}${NC}"
    echo -e "   ${WHITE}  ${DOT}  Token ID  : ${BRIGHT_CYAN}${token_id}${NC}"
    echo -e "   ${WHITE}  ${DOT}  Token Key : ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
    echo -e "   ${WHITE}  ${DOT}  API Port  : ${BRIGHT_CYAN}${api_port}${NC}"
    echo -e "   ${WHITE}  ${DOT}  Remote    : ${BRIGHT_CYAN}${panel_url}${NC}"
    echo -e "   ${DARK_GRAY}  ──────────────────────────────────────────────────${NC}"
    echo ""
    printf "   ${WHITE}Apply Configuration? (Y/n/back): ${NC}"
    read -r apply

    case "${apply,,}" in
        "back")
            current_step=5
            run_config_wizard
            return ;;
        "n"|"no")
            echo -e "\n   ${BRIGHT_YELLOW}  Cancelled. No changes written.${NC}"
            pause; return ;;
    esac

    # ── Write config.yml ──────────────────────────────────────
    _wiz_header
    print_header "APPLYING CONFIGURATION"

    mkdir -p /etc/pterodactyl

    print_status "Writing /etc/pterodactyl/config.yml"
    cat > /etc/pterodactyl/config.yml <<CONFEOF
debug: false
uuid: "${node_uuid}"
token_id: "${token_id}"
token: "${token_key}"
api:
  host: "0.0.0.0"
  port: ${api_port}
  ssl:
    enabled: true
    cert: "/etc/certs/wing/fullchain.pem"
    key: "/etc/certs/wing/privkey.pem"
  upload_limit: 100
system:
  data: "/var/lib/pterodactyl/volumes"
  sftp:
    bind_port: 2022
remote: "${panel_url}"
CONFEOF
    check_success "Config written to /etc/pterodactyl/config.yml" "Failed to write config"
    print_divider

    # Start Wings
    print_status "Starting Wings daemon"
    if systemctl restart wings 2>/dev/null; then
        sleep 2
        if systemctl is-active --quiet wings 2>/dev/null; then
            print_success "Wings is RUNNING!"
        else
            print_error "Wings started but may have errors — run: journalctl -u wings -f"
        fi
    else
        print_error "Could not start Wings — run: journalctl -u wings -f"
    fi

    progress_bar "Configuration applied"

    # ── Final success screen ──────────────────────────────────
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║                                                  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  WINGS CONFIGURED & STARTED!         ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║                                                  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "   ${BRIGHT_CYAN}${STAR} ${WHITE}${BD}Next Steps:${NC}"
    echo -e "   ${DARK_GRAY}  ┌─────────────────────────────────────────────────${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}1.${NC} Verify node is connected in the Panel"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}2.${NC} Check status:  ${BRIGHT_GREEN}sudo systemctl status wings${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}3.${NC} View logs:     ${BRIGHT_GREEN}sudo journalctl -u wings -f${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}4.${NC} Use helper:    ${BRIGHT_MAGENTA}wing${NC}"
    echo -e "   ${DARK_GRAY}  └─────────────────────────────────────────────────${NC}"
    echo ""
    echo -e "   ${DIM}${CYAN}Installed by ProXLegendYT Installer Script${NC}"
    echo ""
    pause
}

# ═══════════════════════════════════════════════════════════════
#   OPTION 2 — AUTO-DEPLOY  (Reset config & deploy token)
# ═══════════════════════════════════════════════════════════════
run_autodeploy() {
    _wings_configurator_header
    print_header "AUTO-DEPLOY — Reset Config & Deploy Token"

    if [ "$EUID" -ne 0 ]; then
        print_error "Must be run as root!"; pause; return
    fi

    if [ ! -f /usr/local/bin/wings ]; then
        print_error "Wings is not installed yet."
        print_info  "Please run Auto-Setup [1] first."
        pause; return
    fi

    echo -e "   ${WHITE}${BD}Paste your Wings deploy token from the Pterodactyl panel:${NC}"
    echo -e "   ${DIM}(Panel → Node → Configuration → Reset Daemon Token)${NC}"
    echo ""
    printf "   ${BRIGHT_GREEN}${ARROW}${NC} ${WHITE}Deploy Token: ${NC}"
    read -r deploy_token

    if [[ -z "$deploy_token" ]]; then
        print_error "Token cannot be empty."; pause; return
    fi

    print_divider
    print_status "Stopping Wings daemon"
    systemctl stop wings 2>/dev/null || true
    print_success "Wings stopped"

    print_divider
    print_status "Applying deploy token configuration"
    if wings configure --allow-insecure --token "$deploy_token" 2>/dev/null; then
        print_success "Configuration applied via deploy token"
    else
        print_error "Auto-configure failed — writing token manually to config"
        if [ -f /etc/pterodactyl/config.yml ]; then
            # Patch existing config token fields
            sed -i "s|^token:.*|token: \"${deploy_token}\"|" /etc/pterodactyl/config.yml
            print_success "Token updated in existing config.yml"
        else
            print_error "No existing config.yml found — run Auto-Setup [1] first"
            pause; return
        fi
    fi

    print_divider
    print_status "Starting Wings daemon"
    if systemctl start wings 2>/dev/null; then
        sleep 2
        if systemctl is-active --quiet wings 2>/dev/null; then
            print_success "Wings is RUNNING!"
        else
            print_error "Wings may have errors — run: journalctl -u wings -f"
        fi
    else
        print_error "Failed to start Wings — run: journalctl -u wings -f"
    fi

    progress_bar "Auto-Deploy"

    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  Auto-Deploy Complete!               ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    pause
}

# ═══════════════════════════════════════════════════════════════
#   MAIN LOOP
# ═══════════════════════════════════════════════════════════════
while true; do
    show_main_menu
    read -r menu_choice

    case "$menu_choice" in
        1) run_autosetup ;;
        2) run_autodeploy ;;
        0)
            clear
            echo ""
            echo -e "   ${BRIGHT_CYAN}${BD}  ${STAR}  Goodbye! — ProXLegendYT Wings Installer${NC}"
            echo ""
            exit 0 ;;
        *)
            echo -e "\n   ${BRIGHT_RED}  ${CROSSMARK}  Invalid option — choose 0, 1 or 2.${NC}"
            sleep 1 ;;
    esac
done
