# ═══════════════════════════════════════════════════════════════
#   MODULE 5 — DATABASE MANAGER  (MySQL / MariaDB)
# ═══════════════════════════════════════════════════════════════
module_database() {
    while true; do
        clear; echo ""
        echo -e "   ${BRIGHT_MAGENTA}┌──────────────────────────────────────────────────────┐${NC}"
        echo -e "   ${BRIGHT_MAGENTA}│${NC}  ${BRIGHT_MAGENTA}${BD}🗄  DATABASE MANAGER${NC}  ${DARK_GRAY}::${NC}  ${DIM}MySQL / MariaDB${NC}"
        echo -e "   ${BRIGHT_MAGENTA}└──────────────────────────────────────────────────────┘${NC}"
        echo ""
        echo -e "   ${BRIGHT_CYAN}  [1]${NC}  ${WHITE}Install MariaDB${NC}"
        echo -e "   ${BRIGHT_GREEN}  [2]${NC}  ${WHITE}Create Pterodactyl Database & User${NC}"
        echo -e "   ${BRIGHT_YELLOW}  [3]${NC}  ${WHITE}Open MySQL Shell${NC}"
        echo -e "   ${BRIGHT_RED}  [4]${NC}  ${WHITE}Show All Databases${NC}"
        echo -e "   ${DARK_GRAY}  [0]${NC}  ${WHITE}Back${NC}"
        echo ""
        echo -e "   ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
        echo ""
        printf "   ${BRIGHT_MAGENTA}root@db-manager:~# ${NC}"; read -r dc

        case "$dc" in
            1)
                clear; print_header "INSTALL MARIADB"
                require_root || continue
                print_status "Installing MariaDB"
                (apt-get update -qq >/dev/null 2>&1 && apt-get install -y -qq mariadb-server >/dev/null 2>&1) &
                spinner "MariaDB installation"
                (systemctl enable --now mariadb >/dev/null 2>&1) &
                spinner "MariaDB service"
                print_success "MariaDB installed and running"
                progress_bar "Database setup"
                pause ;;
            2)
                clear; print_header "CREATE PTERODACTYL DATABASE"
                require_root || continue
                echo -ne "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}Database name (default: panel): ${NC}"; read -r db_name
                [[ -z "$db_name" ]] && db_name="panel"
                echo -ne "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}DB username (default: pterodactyl): ${NC}"; read -r db_user
                [[ -z "$db_user" ]] && db_user="pterodactyl"
                echo -ne "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}DB password: ${NC}"; read -r db_pass
                [[ -z "$db_pass" ]] && { print_error "Password cannot be empty."; pause; continue; }

                print_status "Creating database and user"
                mysql -u root <<SQLEOF 2>/dev/null
CREATE DATABASE IF NOT EXISTS \`${db_name}\`;
CREATE USER IF NOT EXISTS '${db_user}'@'127.0.0.1' IDENTIFIED BY '${db_pass}';
GRANT ALL PRIVILEGES ON \`${db_name}\`.* TO '${db_user}'@'127.0.0.1';
FLUSH PRIVILEGES;
SQLEOF
                if [ $? -eq 0 ]; then
                    print_success "Database '${db_name}' created"
                    print_success "User '${db_user}'@'127.0.0.1' created"
                    print_info "Password saved — use it in your panel config"
                else
                    print_error "Failed — is MariaDB installed and running?"
                fi
                pause ;;
            3)
                clear; echo -e "   ${DIM}Type 'exit' to leave MySQL shell${NC}"; echo ""
                mysql -u root 2>/dev/null || { print_error "Cannot connect to MySQL — is MariaDB running?"; pause; }
                ;;
            4)
                clear; print_header "ALL DATABASES"
                mysql -u root -e "SHOW DATABASES;" 2>/dev/null \
                    || print_error "Cannot connect to MySQL"
                pause ;;
            0) break ;;
            *) echo -e "\n   ${BRIGHT_RED}  ${CROSSMARK}  Invalid.${NC}"; sleep 1 ;;
        esac
    done
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 6 — UNINSTALL  (Remove Wings)
# ═══════════════════════════════════════════════════════════════
module_uninstall() {
    clear; show_banner
    print_header "UNINSTALL — Remove Wings"
    require_root || return

    echo -e "   ${BRIGHT_RED}${BD}⚠  WARNING: This will completely remove Wings!${NC}"
    echo -e "   ${DIM}  The following will be deleted:${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  /usr/local/bin/wings"
    echo -e "   ${DARK_GRAY}  │${NC}  /etc/systemd/system/wings.service"
    echo -e "   ${DARK_GRAY}  │${NC}  /etc/pterodactyl/ (config directory)"
    echo -e "   ${DARK_GRAY}  │${NC}  /etc/certs/wing/ (SSL certificates)"
    echo -e "   ${DARK_GRAY}  │${NC}  /usr/local/bin/wing (helper)"
    echo ""
    printf "   ${BRIGHT_RED}  Type 'YES' to confirm: ${NC}"; read -r confirm
    if [[ "$confirm" != "YES" ]]; then
        echo -e "   ${CYAN}  Cancelled. Nothing was removed.${NC}"
        pause; return
    fi

    print_divider
    print_status "Stopping and disabling Wings service"
    systemctl stop    wings 2>/dev/null || true
    systemctl disable wings 2>/dev/null || true
    print_success "Wings service stopped"

    print_status "Removing Wings binary"
    rm -f /usr/local/bin/wings && print_success "Binary removed" || print_error "Binary not found"

    print_status "Removing Wings service file"
    rm -f /etc/systemd/system/wings.service
    systemctl daemon-reload >/dev/null 2>&1
    print_success "Service file removed"

    print_status "Removing config directory"
    rm -rf /etc/pterodactyl && print_success "/etc/pterodactyl removed" || print_error "Config dir not found"

    print_status "Removing SSL certificates"
    rm -rf /etc/certs/wing && print_success "SSL certs removed" || print_error "Cert dir not found"

    print_status "Removing wing helper"
    rm -f /usr/local/bin/wing && print_success "Helper removed" || print_error "Helper not found"

    progress_bar "Uninstall"
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  Wings Uninstalled Successfully!     ${BRIGHT_GREEN}   ║${NC}"
