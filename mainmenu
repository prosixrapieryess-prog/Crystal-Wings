#!/bin/bash
set -e

# ═══════════════════════════════════════════════════════════════
#   COLORS & STYLES
# ═══════════════════════════════════════════════════════════════
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BRIGHT_RED='\033[1;31m'
BRIGHT_GREEN='\033[1;32m'
BRIGHT_YELLOW='\033[1;33m'
BRIGHT_BLUE='\033[1;34m'
BRIGHT_CYAN='\033[1;36m'
BRIGHT_MAGENTA='\033[1;35m'
DARK_GRAY='\033[1;30m'
NC='\033[0m'
BD='\033[1m'
DIM='\033[2m'
BLINK='\033[5m'

# ═══════════════════════════════════════════════════════════════
#   UI SYMBOLS
# ═══════════════════════════════════════════════════════════════
CHECKMARK="✔"
CROSSMARK="✘"
ARROW="➤"
STAR="★"
DOT="•"
SPINNER_FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")

# ═══════════════════════════════════════════════════════════════
#   HOLOGRAM BANNER
# ═══════════════════════════════════════════════════════════════
show_banner() {
    clear
    echo ""
    # Animated hologram flicker effect
    for i in 1 2 3; do
        echo -e "${BRIGHT_CYAN}${BD}"
        echo '   ██████╗ ██████╗  ██████╗ ██╗  ██╗██╗     ███████╗ ██████╗ ███████╗███╗  ██╗██████╗ ██╗   ██╗████████╗'
        echo '   ██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝██║     ██╔════╝██╔════╝ ██╔════╝████╗ ██║██╔══██╗╚██╗ ██╔╝╚══██╔══╝'
        echo '   ██████╔╝██████╔╝██║   ██║ ╚███╔╝ ██║     █████╗  ██║  ███╗█████╗  ██╔██╗██║██║  ██║ ╚████╔╝    ██║   '
        echo '   ██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗ ██║     ██╔══╝  ██║   ██║██╔══╝  ██║╚████║██║  ██║  ╚██╔╝     ██║   '
        echo '   ██║     ██║  ██║╚██████╔╝██╔╝ ██╗███████╗███████╗╚██████╔╝███████╗██║ ╚███║██████╔╝   ██║       ██║   '
        echo '   ╚═╝     ╚═╝  ╚═╝ ╚═════╝╚═╝   ╚═╝╚══════╝╚══════╝ ╚═════╝ ╚══════╝╚═╝  ╚══╝╚═════╝    ╚═╝       ╚═╝   '
        echo -e "${NC}"
        sleep 0.07
        clear
    done

    # Final stable render with gradient effect
    echo -e "${BRIGHT_BLUE}${BD}"
    echo '   ██████╗ ██████╗  ██████╗ ██╗  ██╗██╗     ███████╗ ██████╗ ███████╗███╗  ██╗██████╗ ██╗   ██╗████████╗'
    echo '   ██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝██║     ██╔════╝██╔════╝ ██╔════╝████╗ ██║██╔══██╗╚██╗ ██╔╝╚══██╔══╝'
    echo '   ██████╔╝██████╔╝██║   ██║ ╚███╔╝ ██║     █████╗  ██║  ███╗█████╗  ██╔██╗██║██║  ██║ ╚████╔╝    ██║   '
    echo '   ██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗ ██║     ██╔══╝  ██║   ██║██╔══╝  ██║╚████║██║  ██║  ╚██╔╝     ██║   '
    echo '   ██║     ██║  ██║╚██████╔╝██╔╝ ██╗███████╗███████╗╚██████╔╝███████╗██║ ╚███║██████╔╝   ██║      ██║   '
    echo '   ╚═╝     ╚═╝  ╚═╝ ╚═════╝╚═╝   ╚═╝╚══════╝╚══════╝ ╚═════╝ ╚══════╝╚═╝  ╚══╝╚═════╝    ╚═╝      ╚═╝   '
    echo -e "${NC}"

    # Glowing underline
    echo -e "   ${BRIGHT_CYAN}▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔${NC}"
    echo ""
    echo -e "   ${DARK_GRAY}${BD}  ◈  ${BRIGHT_CYAN}PTERODACTYL WINGS INSTALLER  ${DARK_GRAY}◈  ${DIM}Automated Setup Script  ${DARK_GRAY}◈  ${BRIGHT_MAGENTA}v2.0${NC}"
    echo -e "   ${BRIGHT_CYAN}▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁▁${NC}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════
#   PRINT HELPERS
# ═══════════════════════════════════════════════════════════════
print_header() {
    local title="$1"
    local width=50
    local pad=$(( (width - ${#title}) / 2 ))
    echo ""
    echo -e "   ${BRIGHT_MAGENTA}╔$(printf '═%.0s' $(seq 1 $width))╗${NC}"
    echo -e "   ${BRIGHT_MAGENTA}║${BRIGHT_CYAN}${BD}$(printf ' %.0s' $(seq 1 $pad)) ${STAR} ${title} ${STAR}$(printf ' %.0s' $(seq 1 $pad))${BRIGHT_MAGENTA}║${NC}"
    echo -e "   ${BRIGHT_MAGENTA}╚$(printf '═%.0s' $(seq 1 $width))╝${NC}"
    echo ""
}

print_status() {
    echo -e "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}$1${YELLOW}...${NC}"
}

print_success() {
    echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}$1${NC}"
}

print_error() {
    echo -e "   ${BRIGHT_RED}  ${CROSSMARK} ${RED}$1${NC}"
}

print_info() {
    echo -e "   ${BRIGHT_CYAN}  ${DOT} ${CYAN}$1${NC}"
}

print_divider() {
    echo -e "   ${DARK_GRAY}  ─────────────────────────────────────────────────${NC}"
}

# ═══════════════════════════════════════════════════════════════
#   CHECK SUCCESS
# ═══════════════════════════════════════════════════════════════
check_success() {
    if [ $? -eq 0 ]; then
        print_success "$1"
        return 0
    else
        print_error "$2"
        return 1
    fi
}

# ═══════════════════════════════════════════════════════════════
#   PROGRESS BAR
# ═══════════════════════════════════════════════════════════════
progress_bar() {
    local label="$1"
    local total=30
    echo -ne "   ${BRIGHT_CYAN}  ${label} [${NC}"
    for i in $(seq 1 $total); do
        echo -ne "${BRIGHT_CYAN}█${NC}"
        sleep 0.03
    done
    echo -e "${BRIGHT_CYAN}] ${BRIGHT_GREEN}${CHECKMARK} Done${NC}"
}

# ═══════════════════════════════════════════════════════════════
#   SHOW BANNER
# ═══════════════════════════════════════════════════════════════
show_banner

# ═══════════════════════════════════════════════════════════════
#   ROOT CHECK
# ═══════════════════════════════════════════════════════════════
if [ "$EUID" -ne 0 ]; then
    echo -e "\n   ${BRIGHT_RED}╔══════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_RED}║  ${CROSSMARK}  ERROR: Must be run as root!       ║${NC}"
    echo -e "   ${BRIGHT_RED}╚══════════════════════════════════════╝${NC}\n"
    exit 1
fi

echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}Running as root — proceeding...${NC}"
sleep 0.5

# ═══════════════════════════════════════════════════════════════
#   1. DOCKER INSTALL
# ═══════════════════════════════════════════════════════════════
print_header "STEP 1 — INSTALLING DOCKER"

print_status "Fetching Docker installation script"
curl -sSL https://get.docker.com/ | CHANNEL=stable bash
check_success "Docker installed successfully" "Docker installation failed"

print_divider
print_status "Enabling Docker service"
sudo systemctl enable --now docker > /dev/null 2>&1
check_success "Docker service is active & enabled" "Failed to start Docker"

progress_bar "Docker setup"

# ═══════════════════════════════════════════════════════════════
#   2. UPDATE GRUB
# ═══════════════════════════════════════════════════════════════
print_header "STEP 2 — CONFIGURING GRUB"

GRUB_FILE="/etc/default/grub"
if [ -f "$GRUB_FILE" ]; then
    print_status "Patching GRUB for swap accounting"
    sudo sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="swapaccount=1"/' $GRUB_FILE
    sudo update-grub > /dev/null 2>&1
    check_success "GRUB updated successfully" "GRUB update failed"
    progress_bar "GRUB configuration"
else
    print_info "GRUB file not found — skipping"
fi

# ═══════════════════════════════════════════════════════════════
#   3. WINGS INSTALL
# ═══════════════════════════════════════════════════════════════
print_header "STEP 3 — INSTALLING WINGS"

print_status "Creating Pterodactyl directory"
sudo mkdir -p /etc/pterodactyl
check_success "Directory /etc/pterodactyl created" "Failed to create directory"

print_divider

print_status "Detecting system architecture"
ARCH=$(uname -m)
if [ "$ARCH" == "x86_64" ]; then
    ARCH="amd64"
    print_info "Architecture detected: ${BRIGHT_WHITE}x86_64 → amd64"
else
    ARCH="arm64"
    print_info "Architecture detected: ${BRIGHT_WHITE}ARM → arm64"
fi

print_divider

print_status "Downloading Wings binary"
curl -L -o /usr/local/bin/wings "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_$ARCH" > /dev/null 2>&1
check_success "Wings binary downloaded to /usr/local/bin/wings" "Failed to download Wings"

print_divider

print_status "Setting executable permissions"
sudo chmod u+x /usr/local/bin/wings
check_success "Permissions set on Wings binary" "Failed to set permissions"

progress_bar "Wings installation"

# ═══════════════════════════════════════════════════════════════
#   4. WINGS SERVICE
# ═══════════════════════════════════════════════════════════════
print_header "STEP 4 — CONFIGURING SYSTEMD SERVICE"

print_status "Writing Wings systemd service file"
WINGS_SERVICE_FILE="/etc/systemd/system/wings.service"
sudo tee $WINGS_SERVICE_FILE > /dev/null <<EOF
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service
PartOf=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=4096
PIDFile=/var/run/wings/daemon.pid
ExecStart=/usr/local/bin/wings
Restart=on-failure
StartLimitInterval=180
StartLimitBurst=30
RestartSec=5s

[Install]
WantedBy=multi-user.target
EOF
check_success "Service file created at $WINGS_SERVICE_FILE" "Failed to create service file"

print_divider

print_status "Reloading systemd daemon"
sudo systemctl daemon-reload > /dev/null 2>&1
check_success "Systemd daemon reloaded" "Failed to reload systemd"

print_divider

print_status "Enabling wings on boot"
sudo systemctl enable wings > /dev/null 2>&1
check_success "Wings service enabled" "Failed to enable service"

progress_bar "Service configuration"

# ═══════════════════════════════════════════════════════════════
#   5. SSL CERTIFICATE
# ═══════════════════════════════════════════════════════════════
print_header "STEP 5 — GENERATING SSL CERTIFICATE"

print_status "Creating certificate directory"
sudo mkdir -p /etc/certs/wing
check_success "Certificate directory ready" "Failed to create directory"

print_divider

print_status "Generating self-signed RSA 4096-bit certificate"
cd /etc/certs/wing || exit
sudo openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
    -subj "/C=NA/ST=NA/L=NA/O=NA/CN=Generic SSL Certificate" \
    -keyout privkey.pem -out fullchain.pem > /dev/null 2>&1
check_success "SSL certificate generated (valid 10 years)" "SSL generation failed"

print_info "Private key : /etc/certs/wing/privkey.pem"
print_info "Certificate : /etc/certs/wing/fullchain.pem"

progress_bar "SSL generation"

# ═══════════════════════════════════════════════════════════════
#   6. HELPER COMMAND
# ═══════════════════════════════════════════════════════════════
print_header "STEP 6 — INSTALLING WING HELPER"

print_status "Creating 'wing' helper command"
sudo tee /usr/local/bin/wing > /dev/null <<'WINGEOF'
#!/bin/bash
CY='\033[0;36m'
BCY='\033[1;36m'
GR='\033[0;32m'
YL='\033[1;33m'
MG='\033[0;35m'
NC='\033[0m'
BD='\033[1m'

echo ""
echo -e "  ${BCY}╔══════════════════════════════════════╗${NC}"
echo -e "  ${BCY}║${MG}${BD}     ⚙  WINGS HELPER COMMANDS         ${BCY}║${NC}"
echo -e "  ${BCY}╠══════════════════════════════════════╣${NC}"
echo -e "  ${BCY}║  ${YL}start   ${NC}→ ${GR}sudo systemctl start wings  ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}stop    ${NC}→ ${GR}sudo systemctl stop wings   ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}restart ${NC}→ ${GR}sudo systemctl restart wings${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}status  ${NC}→ ${GR}sudo systemctl status wings ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}logs    ${NC}→ ${GR}sudo journalctl -u wings -f  ${BCY}║${NC}"
echo -e "  ${BCY}╚══════════════════════════════════════╝${NC}"
echo ""
WINGEOF

sudo chmod +x /usr/local/bin/wing
check_success "Helper command 'wing' installed" "Failed to create helper"

progress_bar "Helper setup"

# ═══════════════════════════════════════════════════════════════
#   COMPLETE
# ═══════════════════════════════════════════════════════════════
echo ""
echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "   ${BRIGHT_GREEN}║                                                  ║${NC}"
echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ✔  INSTALLATION COMPLETE!  ║          ${BRIGHT_GREEN}   ║${NC}"
echo -e "   ${BRIGHT_GREEN}║                                                  ║${NC}"
echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "   ${BRIGHT_CYAN}${STAR} ${WHITE}${BD}Next Steps:${NC}"
echo -e "   ${DARK_GRAY}  ┌─────────────────────────────────────────────────${NC}"
echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}1.${NC} Import your node config into ${BRIGHT_CYAN}/etc/pterodactyl/config.yml${NC}"
echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}2.${NC} Start Wings:   ${BRIGHT_GREEN}sudo systemctl start wings${NC}"
echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}3.${NC} Check status:  ${BRIGHT_GREEN}sudo systemctl status wings${NC}"
echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}4.${NC} Use helper:    ${BRIGHT_MAGENTA}wing${NC}"
echo -e "   ${DARK_GRAY}  └─────────────────────────────────────────────────${NC}"
echo ""
echo -e "   ${DIM}${CYAN}Installed by ProxLegendYT Installer Script${NC}"
echo ""
