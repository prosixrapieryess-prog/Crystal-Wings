# ═══════════════════════════════════════════════════════════════
#   PRINT HELPERS
# ═══════════════════════════════════════════════════════════════
print_header() {
    local title="$1"
    local width=50
    local pad=$(( (width - ${#title}) / 2 ))
    echo ""
    echo -e "   ${BRIGHT_MAGENTA}╔$(printf '═%.0s' $(seq 1 $width))╗${NC}"
    echo -e "   ${BRIGHT_MAGENTA}║${BRIGHT_CYAN}${BD}$(printf ' %.0s' $(seq 1 $pad)) ${STAR} ${title} ${STAR}$(printf ' %.0s' $(seq 1 $pad))${BRIGHT_MAGENTA}║${NC}"
    echo -e "   ${BRIGHT_MAGENTA}╚$(printf '═%.0s' $(seq 1 $width))╝${NC}"
    echo ""
}

print_status()  { echo -e "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}$1${YELLOW}...${NC}"; }
print_success() { echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}$1${NC}"; }
print_error()   { echo -e "   ${BRIGHT_RED}  ${CROSSMARK} ${RED}$1${NC}"; }
print_info()    { echo -e "   ${BRIGHT_CYAN}  ${DOT} ${CYAN}$1${NC}"; }
print_divider() { echo -e "   ${DARK_GRAY}  ─────────────────────────────────────────────────${NC}"; }

check_success() {
    if [ $? -eq 0 ]; then print_success "$1"; return 0
    else print_error "$2"; return 1; fi
}

progress_bar() {
    local label="$1"
    local total=30
    echo -ne "   ${BRIGHT_CYAN}  ${label} [${NC}"
    for i in $(seq 1 $total); do
        echo -ne "${BRIGHT_CYAN}█${NC}"
        sleep 0.03
    done
    echo -e "${BRIGHT_CYAN}] ${BRIGHT_GREEN}${CHECKMARK} Done${NC}"
}

pause() {
    echo ""
    echo -e "   ${DARK_GRAY}  ─────────────────────────────────────────────────${NC}"
    echo -ne "   ${DIM}Press ${BRIGHT_CYAN}Enter${NC}${DIM} to return to menu...${NC}"
    read -r
}

# ═══════════════════════════════════════════════════════════════
#   WINGS CONFIGURATOR HEADER  (Image 2 style)
# ═══════════════════════════════════════════════════════════════
_wings_configurator_header() {
    clear
    echo ""
    local hostname_val ip_val daemon_status daemon_color
    hostname_val=$(hostname 2>/dev/null || echo "unknown")
    ip_val=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "unknown")

    if systemctl is-active --quiet wings 2>/dev/null; then
        daemon_status="✔ ONLINE"
        daemon_color="${BRIGHT_GREEN}${BD}"
    else
        daemon_status="${CROSSMARK} OFFLINE"
        daemon_color="${BRIGHT_RED}${BD}"
    fi

    echo -e "   ${BRIGHT_YELLOW}${BD}⚡ WINGS CONFIGURATOR :: v4.5${NC}"
    echo -e "   ${BRIGHT_CYAN}├── SYSTEM INFORMATION${NC}"
    echo -e "   ${WHITE}│   ├── Hostname : ${BRIGHT_CYAN}${hostname_val}${NC}"
    echo -e "   ${WHITE}│   └── IP Addr  : ${BRIGHT_CYAN}${ip_val}${NC}"
    echo -e "   ${BRIGHT_CYAN}├── SERVICE STATUS${NC}"
    echo -e "   ${WHITE}│   └── Daemon   : ${daemon_color}${daemon_status}${NC}"
    echo -e "   ${DARK_GRAY}└────────────────────────────────────────────────────${NC}"
    echo ""
}

