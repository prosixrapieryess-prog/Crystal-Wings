# ── Wings Configurator header ────────────────────────────────
_wings_header() {
    clear; echo ""
    local hn ip ds dc
    hn=$(hostname 2>/dev/null || echo "unknown")
    ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
    if systemctl is-active --quiet wings 2>/dev/null; then ds="${CHECKMARK} ONLINE";  dc="${BRIGHT_GREEN}${BD}"
    else                                                   ds="${CROSSMARK} OFFLINE"; dc="${BRIGHT_RED}${BD}"; fi
    echo -e "   ${BRIGHT_YELLOW}${BD}⚡ WINGS CONFIGURATOR :: v4.5${NC}"
    echo -e "   ${BRIGHT_CYAN}├── SYSTEM INFORMATION${NC}"
    echo -e "   ${WHITE}│   ├── Hostname : ${BRIGHT_CYAN}${hn}${NC}"
    echo -e "   ${WHITE}│   └── IP Addr  : ${BRIGHT_CYAN}${ip}${NC}"
    echo -e "   ${BRIGHT_CYAN}├── SERVICE STATUS${NC}"
    echo -e "   ${WHITE}│   └── Daemon   : ${dc}${ds}${NC}"
    echo -e "   ${DARK_GRAY}└────────────────────────────────────────────────────${NC}"
    echo ""
}

# ── Wings Auto-Menu ──────────────────────────────────────────
module_wings() {
    while true; do
        clear; echo ""
        echo -e "   ${BRIGHT_CYAN}══════════════════════════════════════════════════════${NC}"
        echo -e "   ${BRIGHT_CYAN}${BD}          PTERODACTYL WINGS AUTO-MENU${NC}"
        echo -e "   ${BRIGHT_CYAN}══════════════════════════════════════════════════════${NC}"
        echo ""
        echo -e "   ${WHITE}${BD}Select an operation:${NC}"
        echo ""
        echo -e "   ${BRIGHT_CYAN}  [1]${NC} ${WHITE}Auto-Setup${NC}  ${BRIGHT_YELLOW}${BD}(Install Config & Manager)${NC}"
        echo -e "   ${BRIGHT_CYAN}  [2]${NC} ${WHITE}Auto-Deploy${NC} ${BRIGHT_YELLOW}${BD}(Reset Config & Deploy Token)${NC}"
        echo -e "   ${BRIGHT_RED}  [0]${NC} ${WHITE}Back${NC}"
        echo ""
        echo -e "   ${BRIGHT_CYAN}══════════════════════════════════════════════════════${NC}"
        echo ""
        printf "   ${WHITE}Enter option [0-2]: ${NC}"
        read -r wopt
        case "$wopt" in
            1) wings_autosetup ;;
            2) wings_autodeploy ;;
            0) break ;;
            *) echo -e "\n   ${BRIGHT_RED}  ${CROSSMARK}  Invalid option.${NC}"; sleep 1 ;;
        esac
    done
}

wings_autosetup() {
    _wings_header
    require_root || return

    echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}Running as root — proceeding...${NC}"; sleep 0.5

    # STEP 1 — Docker
    print_header "STEP 1 — INSTALLING DOCKER"
    if command -v docker &>/dev/null; then
        print_info "Docker already installed — skipping"
    else
        print_status "Fetching Docker installation script"
        curl -sSL https://get.docker.com/ | CHANNEL=stable bash
        check_ok "Docker installed successfully" "Docker installation failed"
    fi
    print_divider
    print_status "Enabling Docker service"
    (systemctl enable --now docker >/dev/null 2>&1) &
    spinner "Docker service"
    progress_bar "Docker setup"

    # STEP 2 — GRUB
    print_header "STEP 2 — CONFIGURING GRUB"
    local GRUB_FILE="/etc/default/grub"
    if [ -f "$GRUB_FILE" ]; then
        print_status "Patching GRUB for swap accounting"
        sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="swapaccount=1"/' "$GRUB_FILE"
        update-grub >/dev/null 2>&1 || true
        print_success "GRUB updated successfully"
        progress_bar "GRUB configuration"
    else
        print_info "GRUB file not found — skipping"
    fi

    # STEP 3 — Wings binary
    print_header "STEP 3 — INSTALLING WINGS"
    print_status "Creating Pterodactyl directory"
    mkdir -p /etc/pterodactyl
    print_success "Directory /etc/pterodactyl ready"
    print_divider

    local ARCH; ARCH=$(uname -m)
    [[ "$ARCH" == "x86_64" ]] && ARCH="amd64" && print_info "Architecture: x86_64 → amd64" \
                               || ARCH="arm64" && print_info "Architecture: ARM → arm64"
    print_divider

    print_status "Downloading Wings binary"
    (curl -fsSL -o /usr/local/bin/wings \
        "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_${ARCH}" >/dev/null 2>&1) &
    spinner "Downloading wings_linux_${ARCH}"
    chmod u+x /usr/local/bin/wings
    print_success "Wings binary ready at /usr/local/bin/wings"
    progress_bar "Wings installation"

    # STEP 4 — Systemd service
    print_header "STEP 4 — CONFIGURING SYSTEMD SERVICE"
    print_status "Writing Wings service file"
    tee /etc/systemd/system/wings.service >/dev/null <<'SVCEOF'
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service
PartOf=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=4096
PIDFile=/var/run/wings/daemon.pid
ExecStart=/usr/local/bin/wings
Restart=on-failure
StartLimitInterval=180
StartLimitBurst=30
RestartSec=5s

[Install]
WantedBy=multi-user.target
SVCEOF
    systemctl daemon-reload >/dev/null 2>&1
    systemctl enable wings   >/dev/null 2>&1
    print_success "Wings service enabled"
    progress_bar "Service configuration"

    # STEP 5 — SSL cert
    print_header "STEP 5 — GENERATING SSL CERTIFICATE"
    print_status "Generating self-signed RSA 4096-bit certificate"
    mkdir -p /etc/certs/wing
    (openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
        -subj "/C=NA/ST=NA/L=NA/O=NA/CN=Generic SSL Certificate" \
        -keyout /etc/certs/wing/privkey.pem \
        -out    /etc/certs/wing/fullchain.pem >/dev/null 2>&1) &
    spinner "SSL Certificate (RSA 4096)"
    print_info "Private key : /etc/certs/wing/privkey.pem"
    print_info "Certificate : /etc/certs/wing/fullchain.pem"
    progress_bar "SSL generation"

    # STEP 6 — Helper
    print_header "STEP 6 — INSTALLING WING HELPER"
    tee /usr/local/bin/wing >/dev/null <<'WEOF'
#!/bin/bash
BCY='\033[1;36m'; YL='\033[1;33m'; GR='\033[0;32m'; MG='\033[0;35m'; NC='\033[0m'; BD='\033[1m'
echo ""
echo -e "  ${BCY}╔══════════════════════════════════════╗${NC}"
echo -e "  ${BCY}║${MG}${BD}   ⚙  WINGS HELPER — ProXLegendYT    ${BCY}║${NC}"
echo -e "  ${BCY}╠══════════════════════════════════════╣${NC}"
echo -e "  ${BCY}║  ${YL}start   ${NC}→ ${GR}sudo systemctl start wings  ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}stop    ${NC}→ ${GR}sudo systemctl stop wings   ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}restart ${NC}→ ${GR}sudo systemctl restart wings${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}status  ${NC}→ ${GR}sudo systemctl status wings ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}logs    ${NC}→ ${GR}sudo journalctl -u wings -f  ${BCY}║${NC}"
echo -e "  ${BCY}╚══════════════════════════════════════╝${NC}"
echo ""
WEOF
    chmod +x /usr/local/bin/wing
    print_success "Helper command 'wing' installed"
    progress_bar "Helper setup"

    echo ""
