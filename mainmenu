# ═══════════════════════════════════════════════════════════════
#   PRINT HELPERS
# ═══════════════════════════════════════════════════════════════
print_header() {
    echo ""
    echo -e "   ${BRIGHT_MAGENTA}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_MAGENTA}║${BRIGHT_CYAN}${BD}   ⚡  $1${NC}"
    echo -e "   ${BRIGHT_MAGENTA}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
}

print_status()  { echo -e "   ${BRIGHT_YELLOW}  ${ARROW} ${WHITE}$1${YELLOW}...${NC}"; }
print_success() { echo -e "   ${BRIGHT_GREEN}  ${CHECKMARK} ${GREEN}$1${NC}"; }
print_error()   { echo -e "   ${BRIGHT_RED}  ${CROSSMARK} ${RED}$1${NC}"; }
print_info()    { echo -e "   ${BRIGHT_CYAN}  • ${CYAN}$1${NC}"; }

check_success() {
    if [ $? -eq 0 ]; then print_success "$1"; return 0;
    else print_error "$2"; return 1; fi
}

progress_bar() {
    local label="$1"
    echo -ne "   ${BRIGHT_CYAN}  ${label} [${NC}"
    for i in $(seq 1 30); do echo -ne "${BRIGHT_CYAN}█${NC}"; sleep 0.02; done
    echo -e "${BRIGHT_CYAN}] ${BRIGHT_GREEN}${CHECKMARK} Done${NC}"
}

pause() {
    echo ""
    echo -e "   ${DARK_GRAY}──────────────────────────────────────────────────${NC}"
    echo -ne "   ${DIM}Press ${BRIGHT_CYAN}Enter${NC}${DIM} to return to menu...${NC}"
    read
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 1 — SSL CONFIGURATION
# ═══════════════════════════════════════════════════════════════
module_ssl() {
    clear
    print_header "SSL CONFIGURATION  ::  Certbot / Nginx"

    if ! command -v nginx &>/dev/null; then
        print_status "Installing Nginx"
        sudo apt update -qq && sudo apt install -y nginx > /dev/null 2>&1
        check_success "Nginx installed" "Failed to install Nginx"
    else
        print_info "Nginx already installed"
    fi

    if ! command -v certbot &>/dev/null; then
        print_status "Installing Certbot"
        sudo apt install -y certbot python3-certbot-nginx > /dev/null 2>&1
        check_success "Certbot installed" "Failed to install Certbot"
    else
        print_info "Certbot already installed"
    fi

    echo ""
    echo -ne "   ${BRIGHT_YELLOW}  Enter your domain (e.g. panel.example.com): ${NC}"
    read domain
    echo -ne "   ${BRIGHT_YELLOW}  Enter your email for Let's Encrypt: ${NC}"
    read email

    print_status "Requesting SSL certificate for ${domain}"
    sudo certbot --nginx -d "$domain" --email "$email" --agree-tos --non-interactive
    check_success "SSL certificate issued for ${domain}" "SSL request failed — check domain DNS"
    progress_bar "SSL setup"
    pause
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 2 — INSTALL WINGS  (ProXLegendYT Script)
# ═══════════════════════════════════════════════════════════════
module_install_wings() {
    clear
    print_header "INSTALL WINGS  ::  ProXLegendYT Script"

    # Root check
    if [ "$EUID" -ne 0 ]; then
        print_error "Must be run as root"
        pause; return
    fi

    # ── Docker ──────────────────────────────────────────────
    print_header "STEP 1 — DOCKER"
    print_status "Installing Docker"
    curl -sSL https://get.docker.com/ | CHANNEL=stable bash
    check_success "Docker installed" "Docker installation failed"

    print_status "Enabling Docker service"
    systemctl enable --now docker > /dev/null 2>&1
    check_success "Docker service active" "Failed to start Docker"
    progress_bar "Docker"

    # ── GRUB ────────────────────────────────────────────────
    print_header "STEP 2 — GRUB"
    GRUB_FILE="/etc/default/grub"
    if [ -f "$GRUB_FILE" ]; then
        print_status "Patching GRUB swap accounting"
        sed -i 's/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT="swapaccount=1"/' $GRUB_FILE
        update-grub > /dev/null 2>&1
        check_success "GRUB updated" "GRUB update failed"
        progress_bar "GRUB"
    else
        print_info "GRUB file not found — skipping"
    fi

    # ── Wings Binary ────────────────────────────────────────
    print_header "STEP 3 — WINGS BINARY"
    print_status "Creating /etc/pterodactyl"
    mkdir -p /etc/pterodactyl
    check_success "Directory created" "Failed"

    ARCH=$(uname -m)
    [ "$ARCH" == "x86_64" ] && ARCH="amd64" || ARCH="arm64"
    print_info "Architecture: ${ARCH}"

    print_status "Downloading Wings"
    curl -L -o /usr/local/bin/wings \
        "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_${ARCH}" > /dev/null 2>&1
    check_success "Wings downloaded" "Download failed"

    chmod u+x /usr/local/bin/wings
    check_success "Permissions set" "chmod failed"
    progress_bar "Wings binary"

    # ── Systemd Service ─────────────────────────────────────
    print_header "STEP 4 — SYSTEMD SERVICE"
    print_status "Writing service file"
    tee /etc/systemd/system/wings.service > /dev/null <<EOF
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service
PartOf=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=4096
PIDFile=/var/run/wings/daemon.pid
ExecStart=/usr/local/bin/wings
Restart=on-failure
StartLimitInterval=180
StartLimitBurst=30
RestartSec=5s

[Install]
WantedBy=multi-user.target
EOF
    check_success "Service file created" "Failed"
    systemctl daemon-reload > /dev/null 2>&1
    systemctl enable wings > /dev/null 2>&1
    check_success "Wings service enabled" "Enable failed"
    progress_bar "Systemd service"

    # ── SSL Cert ────────────────────────────────────────────
    print_header "STEP 5 — SELF-SIGNED SSL"
    mkdir -p /etc/certs/wing
    cd /etc/certs/wing || exit
    openssl req -new -newkey rsa:4096 -days 3650 -nodes -x509 \
        -subj "/C=NA/ST=NA/L=NA/O=NA/CN=Generic SSL Certificate" \
        -keyout privkey.pem -out fullchain.pem > /dev/null 2>&1
    check_success "SSL certificate generated (10yr)" "SSL failed"
    print_info "Key  : /etc/certs/wing/privkey.pem"
    print_info "Cert : /etc/certs/wing/fullchain.pem"
    progress_bar "SSL"

    # ── Helper ──────────────────────────────────────────────
    print_header "STEP 6 — WING HELPER"
    tee /usr/local/bin/wing > /dev/null <<'WINGEOF'
#!/bin/bash
BCY='\033[1;36m'; YL='\033[1;33m'; GR='\033[0;32m'; MG='\033[0;35m'; NC='\033[0m'; BD='\033[1m'
echo ""
echo -e "  ${BCY}╔══════════════════════════════════════╗${NC}"
echo -e "  ${BCY}║${MG}${BD}   ⚙  WINGS HELPER — ProXLegendYT    ${BCY}║${NC}"
echo -e "  ${BCY}╠══════════════════════════════════════╣${NC}"
echo -e "  ${BCY}║  ${YL}start   ${NC}→ ${GR}sudo systemctl start wings  ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}stop    ${NC}→ ${GR}sudo systemctl stop wings   ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}restart ${NC}→ ${GR}sudo systemctl restart wings${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}status  ${NC}→ ${GR}sudo systemctl status wings ${BCY}║${NC}"
echo -e "  ${BCY}║  ${YL}logs    ${NC}→ ${GR}sudo journalctl -u wings -f  ${BCY}║${NC}"
echo -e "  ${BCY}╚══════════════════════════════════════╝${NC}"
echo ""
WINGEOF
    chmod +x /usr/local/bin/wing
    check_success "Helper 'wing' installed" "Failed"
    progress_bar "Helper"

    # ── Done ────────────────────────────────────────────────
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ✔  WINGS INSTALLED SUCCESSFULLY!           ${BRIGHT_GREEN}  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║                                                  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${YELLOW}Next: import config.yml then run:             ${BRIGHT_GREEN}  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${WHITE}  sudo systemctl start wings                  ${BRIGHT_GREEN}  ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    pause
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 3 — AUTO-SETUP (One-Click)
# ═══════════════════════════════════════════════════════════════
module_autosetup() {
    clear
    print_header "AUTO-SETUP  ::  One-Click Panel + Wings"
    print_info "This will run the official Pterodactyl automated installer."
    echo ""
    echo -ne "   ${BRIGHT_YELLOW}  Proceed? [y/N]: ${NC}"
    read confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        print_status "Launching Pterodactyl auto-installer"
        bash <(curl -s https://pterodactyl-installer.se)
    else
        print_info "Cancelled."
    fi
    pause
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 4 — WINGS MANAGER
# ═══════════════════════════════════════════════════════════════
module_manager() {
    while true; do
        clear
        print_header "WINGS MANAGER"
        echo -e "   ${BRIGHT_CYAN}  [1]${NC} ${WHITE}Start Wings${NC}"
        echo -e "   ${BRIGHT_CYAN}  [2]${NC} ${WHITE}Stop Wings${NC}"
        echo -e "   ${BRIGHT_CYAN}  [3]${NC} ${WHITE}Restart Wings${NC}"
        echo -e "   ${BRIGHT_CYAN}  [4]${NC} ${WHITE}Status${NC}"
        echo -e "   ${BRIGHT_CYAN}  [5]${NC} ${WHITE}Live Logs${NC}"
        echo -e "   ${RED}  [0]${NC} ${RED}Back to Main Menu${NC}"
        echo ""
        echo -ne "   ${BRIGHT_GREEN}root@proxlegendyt:~# ${NC}"
        read mgr_opt
        case $mgr_opt in
            1) systemctl start wings  && print_success "Wings started"  || print_error "Failed" ;;
            2) systemctl stop wings   && print_success "Wings stopped"  || print_error "Failed" ;;
            3) systemctl restart wings && print_success "Wings restarted" || print_error "Failed" ;;
            4) systemctl status wings ;;
            5) journalctl -u wings -f ;;
            0) break ;;
            *) print_error "Invalid option" ;;
        esac
        pause
    done
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 5 — DATABASE MANAGER (MySQL/MariaDB)
# ═══════════════════════════════════════════════════════════════
module_database() {
    clear
    print_header "DATABASE MANAGER  ::  MySQL / MariaDB"

    if ! command -v mysql &>/dev/null; then
        print_status "Installing MariaDB"
        apt update -qq && apt install -y mariadb-server > /dev/null 2>&1
        check_success "MariaDB installed" "Installation failed"
        systemctl enable --now mariadb > /dev/null 2>&1
        print_status "Running secure install"
        mysql_secure_installation
    else
        print_info "MySQL/MariaDB already installed"
    fi

    echo ""
    echo -e "   ${BRIGHT_CYAN}  [1]${NC} ${WHITE}Create Pterodactyl database & user${NC}"
    echo -e "   ${BRIGHT_CYAN}  [2]${NC} ${WHITE}Open MySQL shell${NC}"
    echo -e "   ${RED}  [0]${NC} ${RED}Back${NC}"
    echo ""
    echo -ne "   ${BRIGHT_GREEN}root@proxlegendyt:~# ${NC}"
    read db_opt
    case $db_opt in
        1)
            echo -ne "   ${BRIGHT_YELLOW}  DB name [pterodactyl]: ${NC}"; read dbname; dbname=${dbname:-pterodactyl}
            echo -ne "   ${BRIGHT_YELLOW}  DB user [ptero]:        ${NC}"; read dbuser; dbuser=${dbuser:-ptero}
            echo -ne "   ${BRIGHT_YELLOW}  DB password:            ${NC}"; read -s dbpass; echo ""
            mysql -u root <<SQLEOF
CREATE DATABASE IF NOT EXISTS \`${dbname}\`;
CREATE USER IF NOT EXISTS '${dbuser}'@'127.0.0.1' IDENTIFIED BY '${dbpass}';
GRANT ALL PRIVILEGES ON \`${dbname}\`.* TO '${dbuser}'@'127.0.0.1' WITH GRANT OPTION;
FLUSH PRIVILEGES;
SQLEOF
            check_success "Database '${dbname}' and user '${dbuser}' created" "SQL failed"
            ;;
        2)
            mysql -u root
            ;;
    esac
    pause
}

# ═══════════════════════════════════════════════════════════════
#   MODULE 6 — UNINSTALL WINGS
# ═══════════════════════════════════════════════════════════════
module_uninstall() {
    clear
    print_header "UNINSTALL  ::  Remove Wings"
    echo -e "   ${BRIGHT_RED}  ⚠  This will REMOVE Wings, its service, and config files.${NC}"
    echo ""
    echo -ne "   ${BRIGHT_YELLOW}  Are you sure? Type YES to confirm: ${NC}"
    read confirm
    if [ "$confirm" == "YES" ]; then
        print_status "Stopping Wings service"
        systemctl stop wings  > /dev/null 2>&1 || true
        systemctl disable wings > /dev/null 2>&1 || true
        check_success "Service stopped & disabled" "Service stop failed (may not be running)"

        print_status "Removing Wings binary"
        rm -f /usr/local/bin/wings /usr/local/bin/wing
        check_success "Binaries removed" "Remove failed"

        print_status "Removing service file"
        rm -f /etc/systemd/system/wings.service
        systemctl daemon-reload > /dev/null 2>&1
        check_success "Service file removed" "Failed"

        print_status "Removing config directory"
        rm -rf /etc/pterodactyl
        check_success "Config directory removed" "Failed"

        print_status "Removing SSL certs"
        rm -rf /etc/certs/wing
        check_success "Certs removed" "Failed"

        echo ""
        print_success "Wings fully uninstalled."
    else
        print_info "Uninstall cancelled."
    fi
    pause
}

