# ═══════════════════════════════════════════════════════════════
#   SYSTEM INFO HELPERS
# ═══════════════════════════════════════════════════════════════
get_os()  { grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d= -f2 | tr -d '"' || uname -s; }
get_ram() { free -h 2>/dev/null | awk '/Mem:/{print $2"/"$3}' || echo "N/A"; }
get_wan() { curl -s --max-time 3 ifconfig.me 2>/dev/null || echo "N/A"; }
get_lan() { hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A"; }

