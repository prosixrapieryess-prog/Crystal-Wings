    wings_config_wizard
}

wings_config_wizard() {
    local node_uuid="" token_id="" token_key="" api_port="" panel_url=""

    # ── mask token key ──────────────────────────────────────
    _mask() { printf '%*s' "${#1}" '' | tr ' ' '*'; }

    # ── Wizard header (matches image exactly) ───────────────
    _wiz_hdr() {
        clear
        echo ""
        # System info panel
        local hn ip ds dc
        hn=$(hostname 2>/dev/null || echo "unknown")
        ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
        if systemctl is-active --quiet wings 2>/dev/null; then
            ds="${CHECKMARK} ONLINE";  dc="${BRIGHT_GREEN}${BD}"
        else
            ds="${CROSSMARK} OFFLINE"; dc="${BRIGHT_RED}${BD}"
        fi

        echo -e "  ${BRIGHT_YELLOW}${BD}⚡ WINGS CONFIGURATOR${NC} ${DARK_GRAY}::${NC} ${BRIGHT_CYAN}v4.5${NC}"
        echo -e "  ${BRIGHT_CYAN}├── SYSTEM INFORMATION${NC}"
        echo -e "  ${WHITE}│   ├── Hostname : ${BRIGHT_CYAN}${hn}${NC}"
        echo -e "  ${WHITE}│   └── IP Addr  : ${BRIGHT_CYAN}${ip}${NC}"
        echo -e "  ${BRIGHT_CYAN}├── SERVICE STATUS${NC}"
        echo -e "  ${WHITE}│   └── Daemon   : ${dc}${ds}${NC}"
        echo -e "  ${DARK_GRAY}└─────────────────────────────────────────────────────${NC}"
        echo ""
        echo -e "  ${WHITE}${BD}CONFIGURATION WIZARD${NC}"
        echo -e "  ${DIM}Enter credentials. Type ${WHITE}${BD}'back'${NC}${DIM} to go to previous step.${NC}"
        echo ""
        echo -e "  ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
        echo ""
    }

    # ── STEP 1: Node UUID ───────────────────────────────────
    step1() {
        while true; do
            _wiz_hdr
            printf "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${NC}"; read -r node_uuid
            [[ "$node_uuid" == "back" ]] && { node_uuid=""; return 1; }
            [[ -z "$node_uuid" ]] && {
                echo -e "  ${BRIGHT_RED}  ${CROSSMARK} UUID cannot be empty.${NC}"; sleep 1; continue
            }
            return 0
        done
    }

    # ── STEP 2: Token ID ────────────────────────────────────
    step2() {
        while true; do
            _wiz_hdr
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo ""
            printf "  ${BRIGHT_GREEN}►${NC}${WHITE}Token ID: ${NC}"; read -r token_id
            [[ "$token_id" == "back" ]] && { token_id=""; return 1; }
            [[ -z "$token_id" ]] && {
                echo -e "  ${BRIGHT_RED}  ${CROSSMARK} Token ID cannot be empty.${NC}"; sleep 1; continue
            }
            return 0
        done
    }

    # ── STEP 3: Token Key ───────────────────────────────────
    step3() {
        while true; do
            _wiz_hdr
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo ""
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token ID: ${BRIGHT_CYAN}${token_id}${NC}"
            echo ""
            printf "  ${BRIGHT_GREEN}►${NC}${WHITE}Token Key: ${NC}"; read -r token_key
            [[ "$token_key" == "back" ]] && { token_key=""; return 1; }
            [[ -z "$token_key" ]] && {
                echo -e "  ${BRIGHT_RED}  ${CROSSMARK} Token Key cannot be empty.${NC}"; sleep 1; continue
            }
            return 0
        done
    }

    # ── STEP 4: API Port ────────────────────────────────────
    step4() {
        while true; do
            _wiz_hdr
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo ""
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token ID: ${BRIGHT_CYAN}${token_id}${NC}"
            echo ""
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token Key: ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
            echo ""
            echo -e "  ${DIM}(Default: 8080) ENTER${NC}"
            printf "  ${BRIGHT_GREEN}►${NC}${WHITE}API Port: ${NC}"; read -r api_port
            [[ "$api_port" == "back" ]] && { api_port=""; return 1; }
            [[ -z "$api_port" ]] && api_port="8080"
            echo -e "  ${BRIGHT_YELLOW}⚠Using Port: ${api_port}${NC}"
            sleep 0.5
            return 0
        done
    }

    # ── STEP 5: Panel URL ───────────────────────────────────
    step5() {
        while true; do
            _wiz_hdr
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
            echo ""
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token ID: ${BRIGHT_CYAN}${token_id}${NC}"
            echo ""
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token Key: ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
            echo ""
            echo -e "  ${DIM}(Default: 8080) ENTER${NC}"
            echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}API Port: ${BRIGHT_CYAN}${api_port}${NC}"
            echo -e "  ${BRIGHT_YELLOW}⚠Using Port: ${api_port}${NC}"
            echo ""
            echo -e "  ${DIM}(Default: https://panel.example.com)${NC}"
            printf "  ${BRIGHT_GREEN}►${NC}${WHITE}Panel URL: ${NC}"; read -r panel_url
            [[ "$panel_url" == "back" ]] && { panel_url=""; return 1; }
            if [[ -z "$panel_url" ]]; then
                panel_url="https://panel.example.com"
                echo -e "  ${BRIGHT_YELLOW}⚠Using Default URL.${NC}"
            else
                echo -e "  ${BRIGHT_YELLOW}⚠Using URL: ${panel_url}${NC}"
            fi
            sleep 0.5
            return 0
        done
    }

    # ── Wizard navigation loop ──────────────────────────────
    local current_step=1
    while true; do
        case $current_step in
            1) step1 && current_step=2 || current_step=1 ;;
            2) step2 && current_step=3 || current_step=1 ;;
            3) step3 && current_step=4 || current_step=2 ;;
            4) step4 && current_step=5 || current_step=3 ;;
            5) step5 && break          || current_step=4  ;;
        esac
    done

    # ── REVIEW SETTINGS (matches image exactly) ─────────────
    _wiz_hdr
    echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Node UUID: ${BRIGHT_CYAN}${node_uuid}${NC}"
    echo ""
    echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token ID: ${BRIGHT_CYAN}${token_id}${NC}"
    echo ""
    echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Token Key: ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
    echo ""
    echo -e "  ${DIM}(Default: 8080) ENTER${NC}"
    echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}API Port: ${BRIGHT_CYAN}${api_port}${NC}"
    echo -e "  ${BRIGHT_YELLOW}⚠Using Port: ${api_port}${NC}"
    echo ""
    echo -e "  ${DIM}(Default: https://panel.example.com)${NC}"
    echo -e "  ${BRIGHT_GREEN}►${NC}${WHITE}Panel URL: ${BRIGHT_CYAN}${panel_url}${NC}"
    echo -e "  ${BRIGHT_YELLOW}⚠Using Default URL.${NC}"
    echo ""
    echo -e "  ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
    echo ""
    echo -e "  ${BRIGHT_CYAN}${BD}REVIEW SETTINGS:${NC}"
    echo -e "  ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
    echo ""
    echo -e "  ${WHITE}${DOT} UUID      : ${BRIGHT_CYAN}${node_uuid}${NC}"
    echo -e "  ${WHITE}${DOT} Token ID  : ${BRIGHT_CYAN}${token_id}${NC}"
    echo -e "  ${WHITE}${DOT} Token Key : ${BRIGHT_CYAN}$(_mask "$token_key")${NC}"
    echo -e "  ${WHITE}${DOT} API Port  : ${BRIGHT_CYAN}${api_port}${NC}"
    echo -e "  ${WHITE}${DOT} Remote    : ${BRIGHT_CYAN}${panel_url}${NC}"
    echo ""
    echo -e "  ${DARK_GRAY}─────────────────────────────────────────────────────${NC}"
    echo ""
    printf "  ${WHITE}Apply Configuration? (Y/n/back): ${NC}"; read -r apply

    case "${apply,,}" in
        "back") wings_config_wizard; return ;;
        "n"|"no")
            echo -e "\n  ${BRIGHT_YELLOW}  Cancelled. No changes written.${NC}"
            pause; return ;;
    esac

    # ── Write config.yml & start Wings ─────────────────────
    _wiz_hdr
    print_header "APPLYING CONFIGURATION"
    mkdir -p /etc/pterodactyl

    print_status "Writing /etc/pterodactyl/config.yml"
    cat > /etc/pterodactyl/config.yml <<CONFEOF
debug: false
uuid: "${node_uuid}"
token_id: "${token_id}"
token: "${token_key}"
api:
  host: "0.0.0.0"
  port: ${api_port}
  ssl:
    enabled: true
    cert: "/etc/certs/wing/fullchain.pem"
    key: "/etc/certs/wing/privkey.pem"
  upload_limit: 100
system:
  data: "/var/lib/pterodactyl/volumes"
  sftp:
    bind_port: 2022
remote: "${panel_url}"
CONFEOF
    print_success "Config written → /etc/pterodactyl/config.yml"
    print_divider

    print_status "Starting Wings daemon"
    if systemctl restart wings 2>/dev/null; then
        sleep 2
        if systemctl is-active --quiet wings 2>/dev/null; then
            print_success "Wings is RUNNING!"
        else
            print_error "Wings may have errors — run: journalctl -u wings -f"
        fi
    else
        print_error "Could not start Wings — run: journalctl -u wings -f"
    fi

    progress_bar "Configuration applied"
    echo ""
    echo -e "   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  WINGS CONFIGURED & STARTED!         ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "   ${DARK_GRAY}  ┌──────────────────────────────────────────────────${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}1.${NC} Check status : ${BRIGHT_GREEN}sudo systemctl status wings${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}2.${NC} View logs    : ${BRIGHT_GREEN}sudo journalctl -u wings -f${NC}"
    echo -e "   ${DARK_GRAY}  │${NC}  ${YELLOW}3.${NC} Use helper   : ${BRIGHT_MAGENTA}wing${NC}"
    echo -e "   ${DARK_GRAY}  └──────────────────────────────────────────────────${NC}"
    pause
}

wings_autodeploy() {
    _wings_header; print_header "AUTO-DEPLOY — Reset Config & Deploy Token"
    require_root || return

    if [ ! -f /usr/local/bin/wings ]; then
        print_error "Wings not installed — run Auto-Setup [1] first."
        pause; return
    fi

    echo -e "   ${WHITE}${BD}Paste your Wings deploy token from the Pterodactyl panel:${NC}"
    echo -e "   ${DIM}(Panel → Node → Configuration → Reset Daemon Token)${NC}"
    echo ""
    printf "   ${BRIGHT_GREEN}${ARROW}${NC} ${WHITE}Deploy Token: ${NC}"; read -r deploy_token
    [[ -z "$deploy_token" ]] && { print_error "Token cannot be empty."; pause; return; }

    print_divider
    print_status "Stopping Wings"
    systemctl stop wings 2>/dev/null || true
    print_success "Wings stopped"

    print_status "Applying deploy token"
    if wings configure --allow-insecure --token "$deploy_token" 2>/dev/null; then
        print_success "Configuration applied via deploy token"
    else
        if [ -f /etc/pterodactyl/config.yml ]; then
            sed -i "s|^token:.*|token: \"${deploy_token}\"|" /etc/pterodactyl/config.yml
            print_success "Token patched in config.yml"
        else
            print_error "No config.yml — run Auto-Setup first"; pause; return
        fi
    fi

    print_status "Starting Wings"
    if systemctl start wings 2>/dev/null; then
        sleep 2
        systemctl is-active --quiet wings 2>/dev/null \
            && print_success "Wings is RUNNING!" \
            || print_error "Wings may have errors — run: journalctl -u wings -f"
    else
        print_error "Failed to start Wings"
    fi

    progress_bar "Auto-Deploy"
    echo -e "\n   ${BRIGHT_GREEN}╔══════════════════════════════════════════════════╗${NC}"
    echo -e "   ${BRIGHT_GREEN}║  ${BRIGHT_CYAN}${BD}  ${CHECKMARK}  Auto-Deploy Complete!               ${BRIGHT_GREEN}   ║${NC}"
    echo -e "   ${BRIGHT_GREEN}╚══════════════════════════════════════════════════╝${NC}"
    pause
}

